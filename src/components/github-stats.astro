---

---

<section
  id="github-stats"
  class="py-20 bg-gradient-to-br from-[#0a0a0a] to-[#112240]"
>
  <div class="container mx-auto px-6">
    <!-- Heading -->
    <div class="text-center mb-16 github-header">
      <p class="text-[#64ffda] font-medium mb-2">&lt; github stats /&gt;</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        GitHub Activity
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        My contributions and coding activity on GitHub
      </p>
    </div>

    <!-- Stats Container -->
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto github-stats-container"
    >
      <!-- GitHub Stats Card -->
      <div class="github-card" data-aos="fade-up" data-aos-duration="800">
        <img
          id="github-stats-img"
          src="https://github-readme-stats.vercel.app/api?username=gunapalani&show_icons=true&theme=dark&bg_color=0a0a0a&title_color=64ffda&text_color=ffffff&icon_color=64ffda&border_color=233554&hide_border=false&card_width=400&cache_seconds=86400"
          alt="GitHub Stats"
          class="w-full rounded-lg border border-[#233554] hover:border-[#64ffda] transition-colors duration-300 stats-img"
          loading="lazy"
          onerror="this.onerror=null; this.src='https://github-readme-stats-sigma-five.vercel.app/api?username=gunapalani&show_icons=true&theme=dark&bg_color=0a0a0a&title_color=64ffda&text_color=ffffff&icon_color=64ffda&border_color=233554&hide_border=false&card_width=400';"
        />
      </div>

      <div
        class="github-card"
        data-aos="fade-up"
        data-aos-duration="800"
        data-aos-delay="100"
      >
        <img
          id="top-langs-img"
          src="https://github-readme-stats.vercel.app/api/top-langs/?username=gunapalani&layout=compact&theme=dark&bg_color=0a0a0a&title_color=64ffda&text_color=ffffff&border_color=233554&hide_border=false&card_width=400&cache_seconds=86400"
          alt="Top Languages"
          class="w-full rounded-lg border border-[#233554] hover:border-[#64ffda] transition-colors duration-300 stats-img"
          loading="lazy"
          onerror="this.onerror=null; this.src='https://github-readme-stats-sigma-five.vercel.app/api/top-langs/?username=gunapalani&layout=compact&theme=dark&bg_color=0a0a0a&title_color=64ffda&text_color=ffffff&border_color=233554&hide_border=false&card_width=400';"
        />
      </div>
    </div>

    <!-- GitHub Links -->
    <div class="flex justify-center gap-4 mt-12 github-links">
      <a
        href="https://github.com/gunapalani"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#64ffda]/20 hover:bg-[#64ffda]/30 text-[#64ffda] px-6 py-3 rounded-lg border border-[#64ffda] transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
        data-aos="fade-up"
        data-aos-duration="800"
        data-aos-delay="200"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        Visit GitHub Profile
      </a>

      <a
        href="https://github.com/gunapalani?tab=repositories"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#52e0c4]/20 hover:bg-[#52e0c4]/30 text-[#52e0c4] px-6 py-3 rounded-lg border border-[#52e0c4] transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
        data-aos="fade-up"
        data-aos-duration="800"
        data-aos-delay="300"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
          ></path>
        </svg>
        View All Repositories
      </a>
    </div>

    <!-- Stats Info -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <div
        class="text-center p-6 rounded-lg bg-[#112240]/40 border border-[#233554] hover:border-[#64ffda] transition-colors duration-300"
        data-aos="fade-up"
        data-aos-duration="800"
      >
        <div class="text-3xl font-bold text-[#64ffda] mb-2">50+</div>
        <p class="text-gray-400 text-sm">Public Repositories</p>
      </div>

      <div
        class="text-center p-6 rounded-lg bg-[#112240]/40 border border-[#233554] hover:border-[#64ffda] transition-colors duration-300"
        data-aos="fade-up"
        data-aos-duration="800"
        data-aos-delay="100"
      >
        <div class="text-3xl font-bold text-[#64ffda] mb-2">100+</div>
        <p class="text-gray-400 text-sm">Contributions This Year</p>
      </div>

      <div
        class="text-center p-6 rounded-lg bg-[#112240]/40 border border-[#233554] hover:border-[#64ffda] transition-colors duration-300"
        data-aos="fade-up"
        data-aos-duration="800"
        data-aos-delay="200"
      >
        <div class="text-3xl font-bold text-[#64ffda] mb-2">Open Source</div>
        <p class="text-gray-400 text-sm">Contributor</p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    if (typeof gsap !== "undefined" && typeof ScrollTrigger !== "undefined") {
      // Animate GitHub header
      gsap.fromTo(
        ".github-header",
        { opacity: 0, y: 50 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power2.out",
          scrollTrigger: {
            trigger: ".github-header",
            start: "top 80%",
          },
        }
      );

      // Animate stats cards
      gsap.fromTo(
        ".github-card",
        { opacity: 0, y: 30 },
        {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.2,
          ease: "power2.out",
          scrollTrigger: {
            trigger: ".github-stats-container",
            start: "top 75%",
          },
        }
      );

      // Add hover effect to cards
      const cards = document.querySelectorAll(".github-card");
      cards.forEach((card) => {
        card.addEventListener("mouseenter", () => {
          gsap.to(card, {
            y: -8,
            duration: 0.3,
            ease: "power2.out",
          });
        });

        card.addEventListener("mouseleave", () => {
          gsap.to(card, {
            y: 0,
            duration: 0.3,
            ease: "power2.out",
          });
        });
      });
    }
  });
</script>

<style>
  .github-card {
    transition: all 0.3s ease;
  }

  .github-card:hover img {
    filter: brightness(1.05);
  }

  .stats-img {
    min-height: 150px;
    background: linear-gradient(135deg, #0a0a0a 0%, #112240 100%);
  }

  @media (max-width: 768px) {
    .github-stats-container {
      gap: 4;
    }

    .github-links {
      flex-direction: column;
    }

    .github-links a {
      width: 100%;
      justify-content: center;
    }
  }
</style>
